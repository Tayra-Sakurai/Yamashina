                        Spacing="4">
                <controls:SettingsCard x:Name="VoiceSettings"
                                       x:Uid="VoiceSettingCard"
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE767;}">
                    <ToggleSwitch x:Name="VoiceSettingSwitch"/>
                </controls:SettingsCard>
                <controls:SettingsCard x:Uid="SoundElementSetting"
                                       HeaderIcon="{ui:FontIcon Glyph=&#xe767;}">
                    <ToggleSwitch x:Name="ElementSounds"/>
                </controls:SettingsCard>
                <controls:SettingsCard x:Uid="MakeBackup"
                                       HeaderIcon="{ui:FontIcon Glyph=&#xe898;}">
                    <controls:SettingsCard.Description>
                        <TextBlock Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                            <Run x:Uid="MakeBackupDesc"/>
                            <Run Text="{x:Bind backupViewModel.FileSize}"/>
                            <Run x:Uid="MakeBackupDesc2"/>
                        </TextBlock>
                    </controls:SettingsCard.Description>
                    <controls:SettingsCard.Content>
                        <Button x:Uid="BackupMake" Style="{StaticResource AccentButtonStyle}" Command="{StaticResource BackupMakeCommand}"/>
                    </controls:SettingsCard.Content>
                </controls:SettingsCard>
